# Cornell Box
# Classic test scene for global illumination

render width=1024 height=1024 min_samples=16 max_samples=512 qual_thresh=0.05 trace_depth=8

camera z=1.0 d=1.0

# Walls as boxes with thin depth (acting as quads)
# Back wall (white)
box pos=0,0,-4.01 size=4.02,4.02,0.02 color=0.75,0.75,0.75

# Floor (white)
box pos=0,-2.01,-3 size=4.02,0.02,2.02 color=0.75,0.75,0.75

# Ceiling (white)
box pos=0,2.01,-3 size=4.02,0.02,2.02 color=0.75,0.75,0.75

# Left wall (red) - placed at +x so it appears on left in flipped sensor image
box pos=2.01,0,-3 size=0.02,4.02,2.02 color=0.65,0.05,0.05

# Right wall (green) - placed at -x so it appears on right in flipped sensor image
box pos=-2.01,0,-3 size=0.02,4.02,2.02 color=0.12,0.45,0.15


# Tall box (left, rotated) - mirror
box pos=-0.6,-0.7,-3.0 size=1.0,2.6,1.0 rotate_y=18 color=0.95,0.95,0.95 reflectance=0.95 roughness=0.02

# Short box (right, rotated)
box pos=0.7,-1.2,-2.5 size=1.0,1.6,1.0 rotate_y=-15 color=0.75,0.75,0.75

# Glass sphere on top of short box - high dispersion
sphere pos=0.7,-0.1,-2.5 radius=0.5 transparency=0.95 cauchy_a=1.65 cauchy_b=0.015 color=1.0,1.0,1.0

# Area light (rectangular patch on ceiling)
light pos=0,1.98,-3.0 intensity=1.5 size=1.0,1.0 normal=0,-1,0

# Dim fill light near camera
light pos=0,0,-1.5 intensity=0.15 size=2.0,2.0 normal=0,0,-1
