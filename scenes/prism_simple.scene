# Simplest possible test: bright white wall behind a glass prism
# Camera looks through the prism - should see chromatic aberration / rainbow edges

render width=1024 height=1024 min_samples=16 max_samples=512 qual_thresh=0.05 trace_depth=8

camera z=1.0 d=1.0

# Bright white back wall
box pos=0,0,-4.01 size=4.02,4.02,0.02 color=0.9,0.9,0.9

# Glass prism dead center
prism pos=0.0,0.0,-2.5 side=1.5 depth=2.0 rotate_y=0 transparency=0.95 cauchy_a=1.3 cauchy_b=0.04

# Bright area light on ceiling illuminating back wall
light pos=0,1.98,-3.0 intensity=2.0 size=2.0,2.0 normal=0,-1,0
