# Glass spheres scene — pink sphere with nested glass shells
# Single biconvex crown lens, f≈0.595 for infinity focus at sensor

render width=512 height=512 min_samples=16 max_samples=2000 qual_thresh=0.008 trace_depth=32 shadow_rays=0 ghost_rays=0 exposure=0.60 contrast=1.05 saturation=1.00

camera z=0.595 d=0.455
aperture z=-0.05 radius=0.08

# Best-form single lens: optimal shape for minimum spherical aberration
# q=0.77, r1=0.295 (steep, sensor-facing), r2=2.24 (gentle, scene-facing), f=0.498
lens z=0.000  r1=0.295  r2=2.24  radius=0.16 cauchy_a=1.523 cauchy_b=0.006 reflectance=0.02

# Center sphere 
sphere pos=-0.3000,0.0,-3.05 radius=0.9 color=0.99,0.58,0.62 roughness=1.0

# Glass shells 
sphere pos=0.0788,0.0,-3.05 radius=1.0400 color=0.5,0.75,0.75 transparency=0.970 cauchy_a=1.1000 cauchy_b=0.01 phong=1000
sphere pos=-0.1486,0.0,-3.05 radius=1.0780 color=0.5,0.75,0.75 transparency=0.970 cauchy_a=1.1477 cauchy_b=0.0  phong=1000
sphere pos=-0.2274,0.0,-3.05 radius=1.2816 color=0.5,0.75,0.75 transparency=1.0 cauchy_a=1.0347 cauchy_b=0.04 phong=1000
sphere pos=0.0401,0.0,-3.05 radius=1.3792 color=0.5,0.75,0.75 transparency=0.945 cauchy_a=1.1869 cauchy_b=0.021 phong=1000
sphere pos=-0.0760,0.0,-3.05 radius=1.4722 color=0.5,0.75,0.75 transparency=0.995 cauchy_a=1.1608 cauchy_b=0.022 phong=1000
sphere pos=-0.0122,0.0,-3.05 radius=1.6597 color=0.5,0.75,0.75 transparency=0.920 cauchy_a=1.1739 cauchy_b=0.0 phong=1000

# Background plane
plane normal=0,0,1 d=-10 color=1.0,1.0,1.0 emission=5.5 reflectance=0.0 roughness=0.0

# Key light (slightly warm) — no flare
light pos=0,8,5 intensity=3.0 specular=0.0
# Fill lights (cooler, from sides) — no flare
light pos=8,-3,3 intensity=1.5 specular=0.0
light pos=-8,-3,3 intensity=1.5 specular=0.0
# Specular-only lights for bright glints that drive ghost streaks
light pos=5,-4,3 intensity=15.0 specular=500.0 diffuse=0.0
light pos=-4,5,3 intensity=12.0 specular=400.0 diffuse=0.0
