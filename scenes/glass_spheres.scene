# Glass spheres scene — pink sphere with nested glass shells
# 3-element lens: crown biconvex, anamorphic cylinder, flint meniscus

render width=512 height=512 min_samples=512 max_samples=4000 qual_thresh=0.008 trace_depth=32 shadow_rays=0 ghost_rays=1 exposure=0.12 contrast=1.50

camera z=0.595 d=0.455
aperture z=-0.026 radius=0.006

# Front anamorphic cylinder: dominant flare source, dispersive
lens z=0.000  r1=-0.35  r2=0.40  radius=0.25 cauchy_a=1.30 cauchy_b=0.025 reflectance=0.30 anamorphic=1
# Petzval Group 1: low-reflection crown + low-dispersion flint
lens z=-0.018 r1=0.92  r2=0.98  radius=0.22 cauchy_a=1.53 cauchy_b=0.006 reflectance=0.018
lens z=-0.029 r1=-1.35 r2=1.95  radius=0.22 cauchy_a=1.64 cauchy_b=0.014 reflectance=0.10
# Petzval Group 2: low-reflection crown + low-dispersion flint
lens z=-0.046 r1=1.12  r2=1.18  radius=0.22 cauchy_a=1.53 cauchy_b=0.006 reflectance=0.018
lens z=-0.060 r1=-1.55 r2=2.10  radius=0.22 cauchy_a=1.64 cauchy_b=0.014 reflectance=0.045

# Center sphere (darker, more neutral)
sphere pos=-0.3000,0.0,-3.05 radius=0.9 color=0.70,0.65,0.72 roughness=1.0 reflectance=0.0

# Glass shells
sphere pos=0.0788,0.0,-3.05 radius=1.0400 color=0.5,0.75,0.75 transparency=0.90 reflectance=0.10 cauchy_a=1.1000 cauchy_b=0.01 phong=2000
sphere pos=0.0401,0.0,-3.05 radius=1.3792 color=0.5,0.75,0.75 transparency=0.91 reflectance=0.06 cauchy_a=1.1869 cauchy_b=0.01 phong=2000
sphere pos=-0.0122,0.0,-3.05 radius=1.6597 color=0.5,0.75,0.75 transparency=0.96 reflectance=0.04 cauchy_a=1.3739 cauchy_b=0.01 phong=2000
sphere pos=-0.0760,0.0,-3.05 radius=1.4722 color=0.5,0.75,0.75 transparency=0.93 reflectance=0.07 cauchy_a=1.3608 cauchy_b=0.01 phong=2000
sphere pos=-0.1486,0.0,-3.05 radius=1.0780 color=0.5,0.75,0.75 transparency=0.90 reflectance=0.10 cauchy_a=1.2477 cauchy_b=0.01 phong=2000
sphere pos=-0.2274,0.0,-3.05 radius=1.2816 color=0.5,0.75,0.75 transparency=0.92 reflectance=0.12 cauchy_a=1.2347 cauchy_b=0.03 phong=2000

# Background plane
plane normal=0,0,1 d=-10 color=1.0,1.0,1.0 emission=0.0 reflectance=0.0 roughness=0.0

# Key light (slightly warm)
light pos=0,8,5 intensity=3.0
# Fill lights (cooler, from sides)
light pos=8,-3,3 intensity=1.5
light pos=-8,-3,3 intensity=1.5
# Specular-only lights for bright glints that drive ghost streaks
light pos=5,-4,3 intensity=15.0 specular=500.0 diffuse=0.0
light pos=-4,5,3 intensity=12.0 specular=400.0 diffuse=0.0
