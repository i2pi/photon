# Glass spheres scene — pink sphere with nested glass shells
# 3-element lens: crown biconvex, anamorphic cylinder, flint meniscus

render width=512 height=512 min_samples=512 max_samples=4000 qual_thresh=0.008 trace_depth=32 shadow_rays=0 ghost_rays=0 exposure=0.35 contrast=1.2

camera z=0.5 d=0.50
aperture z=-0.02 radius=0.015

# Anamorphic cylinder (front element) — moderate curvature for visible horizontal streaks
lens z=0.000  r1=-0.45  r2=0.55   radius=0.15 cauchy_a=1.02 cauchy_b=0.02 reflectance=0.35 anamorphic=90
# Petzval Group 1: crown biconvex + flint meniscus
lens z=-0.022 r1=1.15  r2=1.15  radius=0.15 cauchy_a=1.52 cauchy_b=0.005 reflectance=0.04
lens z=-0.027 r1=-2.0  r2=2.5   radius=0.15 cauchy_a=1.62 cauchy_b=0.015 reflectance=0.03
# Petzval Group 2: crown biconvex + flint meniscus
lens z=-0.042 r1=1.60  r2=1.60  radius=0.15 cauchy_a=1.52 cauchy_b=0.005 reflectance=0.02
lens z=-0.054 r1=-2.0  r2=2.5   radius=0.15 cauchy_a=1.62 cauchy_b=0.015 reflectance=0.04

# Center sphere — dark metallic core
sphere pos=0.0,0.0,-3.05 radius=0.7 color=0.45,0.50,0.55 roughness=0.02 reflectance=0.30 transparency=0.0 phong=500

# Glass shells — nested concentric with increasing transparency outward
sphere pos=0.0,0.0,-3.05 radius=0.95 color=0.65,0.75,0.80 transparency=0.75 reflectance=0.20 cauchy_a=1.52 cauchy_b=0.01 phong=500
sphere pos=0.0,0.0,-3.05 radius=1.20 color=0.65,0.75,0.80 transparency=0.80 reflectance=0.15 cauchy_a=1.52 cauchy_b=0.01 phong=500
sphere pos=0.0,0.0,-3.05 radius=1.50 color=0.70,0.80,0.85 transparency=0.85 reflectance=0.12 cauchy_a=1.52 cauchy_b=0.01 phong=500
sphere pos=0.0,0.0,-3.05 radius=1.80 color=0.70,0.80,0.85 transparency=0.88 reflectance=0.10 cauchy_a=1.52 cauchy_b=0.01 phong=500

# Background plane
plane normal=0,0,1 d=-10 color=1.0,1.0,1.0 emission=3.5 reflectance=0.0 roughness=0.0

# Key light
light pos=0,8,5 intensity=4.0
# Fill lights
light pos=8,-3,3 intensity=2.5
light pos=-8,-3,3 intensity=2.5
# Specular-only lights for bright glints that drive ghost streaks
light pos=5,-4,3 intensity=2.0 specular=25.0 diffuse=0.0
light pos=-4,5,3 intensity=1.5 specular=20.0 diffuse=0.0

