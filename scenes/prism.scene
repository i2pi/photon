# Glass prism rainbow - soft caustic version

render width=1024 height=1024 min_samples=32 max_samples=1024 qual_thresh=0.05 trace_depth=12

camera z=1.0 d=1.0

# Black room - only caustic light reaches the projection wall
box pos=0,0,-4.01 size=4.02,4.02,0.02 color=0.0,0.0,0.0
box pos=0,-2.01,-3 size=4.02,0.02,2.02 color=0.0,0.0,0.0
box pos=0,2.01,-3 size=4.02,0.02,2.02 color=0.0,0.0,0.0
box pos=2.01,0,-3 size=0.02,4.02,2.02 color=0.0,0.0,0.0

# Projection wall (left) - warm white
box pos=-2.01,0,-3 size=0.02,4.02,2.02 color=0.95,0.93,0.90

# SOLID divider wall at x=0 - NO gap at all
# Top half covers y=0 to y=2.01
box pos=0.0,1.005,-3.0 size=0.04,2.01,2.02 color=0.0,0.0,0.0
# Bottom half covers y=-2.01 to y=0
box pos=0.0,-1.005,-3.0 size=0.04,2.01,2.02 color=0.0,0.0,0.0

# Prism - sits ON the divider wall, straddles x=0
# Shadow rays block on ALL triangles, so direct light can't pass through.
# Only refracted (dispersed) light makes it through as caustic photons.
prism pos=0.2,0.0,-3.0 side=1.0 depth=1.4 rotate_y=0 transparency=0.95 cauchy_a=1.3 cauchy_b=0.04

# Wider slit light for softer, broader rainbow
light pos=1.95,0.0,-3.0 intensity=400.0 size=0.2,0.5 normal=-1,0,0
